# Database
DB_BACKEND=mysql
DB_HOST=localhost
DB_PORT=3306
DB_USER=movie_user
DB_PASSWORD=your_password_here
DB_NAME=movie_recommender
SQLITE_PATH=movie_recommender.db

# Recommendation config
TOP_N_RECOMMENDATIONS=10
MIN_RATING=7.5
YEAR_START=1990
YEAR_END=2026
PREFERRED_GENRES=["Thriller","Psychological","Drama","Horror"]
AVOID_GENRES=["Romance","Musical"]

# Schedule and timezone
SCHEDULE_TIME_SATURDAY=20:00
SCHEDULE_TIME_SUNDAY=20:00
APP_TIMEZONE=

# Google Calendar
GOOGLE_CREDENTIALS_FILE=credentials.json
GOOGLE_TOKEN_FILE=token.json
GOOGLE_CALENDAR_ID=primary
GOOGLE_SCOPES=["https://www.googleapis.com/auth/calendar.events"]
GOOGLE_EVENT_DURATION_MINUTES=150
